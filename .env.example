# MailVault Configuration
# Copy this file to .env and configure for your environment

# ==============================================================================
# Database Configuration
# ==============================================================================
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=mailvault
DB_SSLMODE=disable

# ==============================================================================
# Authentication Provider (supabase or mock)
# ==============================================================================
AUTH_PROVIDER=supabase

# Supabase Configuration (if using supabase)

# JWT Configuration
AUTH_SECRET_KEY=your-super-secret-jwt-key-change-this-in-production
AUTH_TOKEN_TTL=24h

# ==============================================================================
# Server Configuration
# ==============================================================================
# API Server
API_ADDRESS=:8080

# Web Server  
WEB_ADDRESS=:3000

# Admin Server
ADMIN_ADDRESS=:9000

# ==============================================================================
# SMTP Server Configuration
# ==============================================================================
SMTP_ADDR=:25
SMTP_DOMAIN=mail.yourdomain.com

# TLS Configuration for SMTP
SMTP_TLS_MODE=disabled
# SMTP_TLS_MODE=cert       # Use certificate files
# SMTP_TLS_CERT=/path/to/fullchain.pem
# SMTP_TLS_KEY=/path/to/privkey.pem

# ==============================================================================
# Logging Configuration
# ==============================================================================
LOG_LEVEL=info
LOG_ENVIRONMENT=development
LOG_TYPE=text
LOG_STDERR=false