# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=mailsafe
DB_SSLMODE=disable

# API Server Configuration
API_ADDRESS=:8080

# SMTP Server Configuration
SMTP_ADDR=:25
SMTP_DOMAIN=mailsafe.sh

# Optional: TLS Configuration for SMTP
# SMTP_TLS_CERT=/path/to/cert.pem
# SMTP_TLS_KEY=/path/to/key.pem

# Authentication Configuration
AUTH_PROVIDER=basic  # Options: basic, supabase

# Supabase Configuration (if using AUTH_PROVIDER=supabase)
