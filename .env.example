# MailVault configuration. Copy to .env and edit.

# ============================================================================
# Database
# ============================================================================
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DATABASE_NAME=mailvault
DATABASE_SSLMODE=disable

# Connection-pool tuning
DATABASE_POOL_MIN_SIZE=5
DATABASE_POOL_MAX_SIZE=25
DATABASE_MAX_CONN_LIFETIME=3600     # seconds; 0 = no limit
DATABASE_MAX_CONN_IDLE_TIME=900     # seconds
DATABASE_HEALTH_CHECK_PERIOD=60     # seconds

# ============================================================================
# Authentication
# ============================================================================
# Provider: 'local' (built-in users + bcrypt + JWT). The provider interface
# accepts custom implementations registered in cmd/service/auth.go.
AUTH_PROVIDER=local

# JWT signing secret — must be at least 32 bytes. CHANGE THIS IN PRODUCTION.
AUTH_SECRET_KEY=replace-with-32-or-more-random-bytes
AUTH_TOKEN_TTL=24h

# ============================================================================
# API server
# ============================================================================
API_ADDRESS=0.0.0.0:3000
API_BASE_URL=http://localhost:3000

# Prometheus metrics endpoint (separate listener)
METRICS_ADDRESS=:8080

ENABLE_DATABASE_METRICS=true
ENABLE_QUERY_INSTRUMENTATION=true

# ============================================================================
# Inbound SMTP daemon
# ============================================================================
SMTP_ADDR=:25
SMTP_DOMAIN=mail.yourdomain.com

# TLS: off | cert | implicit
SMTP_TLS_MODE=off
# SMTP_TLS_CERT=/path/to/fullchain.pem
# SMTP_TLS_KEY=/path/to/privkey.pem
SMTP_TLS_IMPLICIT=false

# Forward inbound mail to a relay (empty = forwarding disabled).
SMTP_FORWARDING_RELAY_ADDR=

# ============================================================================
# Outbound SMTP relay (used by POST /api/v1/send)
# ============================================================================
# Point at a local MTA (Postfix on the same host) or a smart-host.
OUTBOUND_SMTP_ADDR=localhost:25
OUTBOUND_SMTP_HOSTNAME=localhost
OUTBOUND_SMTP_TLS_MODE=none         # none | starttls | implicit
OUTBOUND_SMTP_USERNAME=
OUTBOUND_SMTP_PASSWORD=

# ============================================================================
# Logging
# ============================================================================
LOG_LEVEL=info
