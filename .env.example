# MailVault Configuration
# Copy this file to .env and configure for your environment

# ==============================================================================
# Database Configuration
# ==============================================================================
# Database connection details
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DATABASE_NAME=mailvault
DATABASE_SSLMODE=disable

# Connection pooling configuration for optimal performance
# Min pool size: minimum number of connections to maintain
DATABASE_POOL_MIN_SIZE=5
# Max pool size: maximum number of connections allowed
DATABASE_POOL_MAX_SIZE=25
# Connection max lifetime in seconds (0 = no limit)
DATABASE_MAX_CONN_LIFETIME=3600
# Connection max idle time in seconds
DATABASE_MAX_CONN_IDLE_TIME=900
# Health check period in seconds
DATABASE_HEALTH_CHECK_PERIOD=60

# Legacy DB_ prefixed variables (deprecated, use DATABASE_ prefixes above)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=mailvault
DB_SSLMODE=disable

# ==============================================================================
# Authentication Provider (supabase or mock)
# ==============================================================================
AUTH_PROVIDER=supabase

# Supabase Configuration (if using supabase)

# JWT Configuration
AUTH_SECRET_KEY=your-super-secret-jwt-key-change-this-in-production
AUTH_TOKEN_TTL=24h

# ==============================================================================
# Server Configuration
# ==============================================================================
# API Server
API_ADDRESS=:8080

# Web Server  
WEB_ADDRESS=:3000

# Admin Server
ADMIN_ADDRESS=:9000

# ==============================================================================
# SMTP Server Configuration
# ==============================================================================
SMTP_ADDR=:25
SMTP_DOMAIN=mail.yourdomain.com

# TLS Configuration for SMTP
SMTP_TLS_MODE=disabled
# SMTP_TLS_MODE=cert       # Use certificate files
# SMTP_TLS_CERT=/path/to/fullchain.pem
# SMTP_TLS_KEY=/path/to/privkey.pem

# ==============================================================================
# Database Optimization Configuration
# ==============================================================================
# Enable database performance metrics
ENABLE_DATABASE_METRICS=true
# Enable query instrumentation for detailed monitoring
ENABLE_QUERY_INSTRUMENTATION=true

# ==============================================================================
# Logging Configuration
# ==============================================================================
LOG_LEVEL=info
LOG_ENVIRONMENT=development
LOG_TYPE=text
LOG_STDERR=false