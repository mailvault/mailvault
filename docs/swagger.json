            "name": "MailVault Support",
            "url": "https://mailvault.sh/support",
            "email": "support@mailvault.sh"
        },
        "license": {
            "name": "MIT",
            "url": "https://github.com/guilhermebr/mailvault/blob/main/LICENSE"
        },
        "version": "1.0"
    },
