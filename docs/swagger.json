                    {
                        "type": "string",
                        "format": "uuid",
                        "description": "Email Address ID",
                        "name": "emailId",
                        "in": "path",
                        "required": true
                    },
                    {
                        "type": "integer",
                        "default": 10,
                        "description": "Number of emails per page",
                        "name": "limit",
                        "in": "query"
                    },
                    {
                        "type": "integer",
                        "default": 0,
                        "description": "Number of emails to skip",
                        "name": "offset",
                        "in": "query"
                    }
